<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ly.ttd.biz.feature.admin.mybatis.mapper.UserAccountMapper">

    <resultMap id="BaseResultMap" type="com.ly.ttd.biz.feature.admin.mybatis.entity.UserAccountEntity">
        <id column="id" property="id"/>
        <result column="user_account" property="userAccount"/>
        <result column="password" property="password"/>
        <result column="crt_user" property="crtUser"/>
        <result column="crt_time" property="crtTime"/>
        <result column="upt_user" property="uptUser"/>
        <result column="upt_time" property="uptTime"/>
        <result column="deleted" property="deleted"/>
    </resultMap>

    <sql id="Base_Column_List">
        id, user_account, password,
        crt_user, crt_time, upt_user, upt_time, deleted
    </sql>
    <select id="selectAll" resultType="com.ly.ttd.biz.feature.admin.mybatis.entity.UserAccountEntity">
        select
        <include refid="Base_Column_List"/>
        from ttd_user_account
        where deleted=0
    </select>


</mapper>
