<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ly.ttd.biz.feature.dem.sweb.service.mybatis.mapper.MetaFieldTestCaseMapper">

    <resultMap id="BaseResultMap" type="com.ly.ttd.biz.feature.dem.sweb.service.mybatis.entity.MetaFieldTestCaseEntity">
        <id column="id" property="id"/>
        <result column="meta_field_code" property="metaFieldCode"/>
        <result column="case_type" property="caseType"/>
        <result column="biz_order_no" property="bizOrderNo"/>
        <result column="case_content" property="caseContent"/>
        <result column="target_value" property="targetValue"/>
        <result column="crt_user" property="crtUser"/>
        <result column="crt_time" property="crtTime"/>
        <result column="upt_user" property="uptUser"/>
        <result column="upt_time" property="uptTime"/>
        <result column="deleted" property="deleted"/>
    </resultMap>

    <sql id="Base_Column_List">
        id, meta_field_code, case_type, biz_order_no,
        case_content, target_value,
        crt_user, crt_time, upt_user, upt_time, deleted
    </sql>

    <sql id="Query_Condition">
        <where>
            deleted = 0
            <if test="req.metaFieldCode != null and req.metaFieldCode != ''">
                AND meta_field_code = #{req.metaFieldCode}
            </if>
            <if test="req.caseType != null and req.caseType != ''">
                AND case_type = #{req.caseType}
            </if>
            <if test="req.bizOrderNo != null and req.bizOrderNo != ''">
                AND biz_order_no LIKE CONCAT('%', #{req.bizOrderNo}, '%')
            </if>
        </where>
    </sql>

    <select id="pageQuery" resultMap="BaseResultMap">
        SELECT
        <include refid="Base_Column_List"/>
        FROM ttd_meta_field_test_case
        <include refid="Query_Condition"/>
        ORDER BY crt_time DESC
    </select>

</mapper>
