<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ly.ttd.biz.feature.dem.sweb.mybatis.rcs.slave.mapper.TableDefMapper">

    <resultMap id="BaseResultMap" type="com.ly.ttd.biz.feature.dem.sweb.mybatis.rcs.slave.entity.TableDef">
        <id property="id" column="id" jdbcType="VARCHAR"/>
        <result property="tableName" column="table_name" jdbcType="VARCHAR"/>
        <result property="dataSource" column="data_source" jdbcType="VARCHAR"/>
        <result property="crtUser" column="crt_user" jdbcType="VARCHAR"/>
        <result property="uptUser" column="upt_user" jdbcType="VARCHAR"/>
        <result property="crtTime" column="crt_time" jdbcType="TIMESTAMP"/>
        <result property="uptTime" column="upt_time" jdbcType="TIMESTAMP"/>
        <result property="deleted" column="deleted" jdbcType="TINYINT"/>
    </resultMap>

    <sql id="Base_Column_List">
        id,table_name,data_source,crt_user,upt_user,
        crt_time,upt_time,deleted
    </sql>


    <!-- 根据ID查询 -->
    <select id="selectById" resultMap="BaseResultMap">
        SELECT <include refid="Base_Column_List"/>
        FROM ttd_table_def
        WHERE id = #{id} AND deleted = 0
    </select>

    <!-- 根据表名查询 -->
    <select id="selectByTableName" resultMap="BaseResultMap">
        SELECT <include refid="Base_Column_List"/>
        FROM ttd_table_def
        WHERE table_name = #{tableName} AND deleted = 0
    </select>

    <!-- 分页查询（带模糊搜索） -->
    <select id="pageQuery" resultType="com.ly.ttd.biz.feature.dem.sweb.mybatis.rcs.slave.entity.TableDef">
        SELECT <include refid="Base_Column_List"/>
        FROM ttd_table_def
        <include refid="Query_Condition"/>
        ORDER BY id DESC
    </select>

    <sql id="Query_Condition">
        <where>
            deleted = 0
            <if test="req.tableName != null and req.tableName != ''">
                AND table_name LIKE CONCAT('%', #{req.tableName}, '%')
            </if>
            <if test="req.dataSource != null and req.dataSource != ''">
                AND data_source = #{req.dataSource}
            </if>
        </where>
    </sql>

    <!-- 查询所有有效的表定义 -->
    <select id="selectAllValid" resultMap="BaseResultMap">
        SELECT <include refid="Base_Column_List"/>
        FROM ttd_table_def
        WHERE deleted = 0
        ORDER BY id DESC
    </select>

</mapper>
