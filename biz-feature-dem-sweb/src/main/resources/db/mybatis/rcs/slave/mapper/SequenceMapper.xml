<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ly.ttd.biz.feature.dem.sweb.mybatis.rcs.slave.mapper.SequenceMapper">

    <resultMap id="BaseResultMap" type="com.ly.ttd.biz.feature.dem.sweb.mybatis.rcs.slave.entity.SequenceEntity">
        <id column="id" property="id"/>
        <result column="seq_code" property="seqCode"/>
        <result column="seq_name" property="seqName"/>
        <result column="val" property="val"/>
    </resultMap>

    <sql id="Base_Column_List">
        id, seq_code, seq_name, val
    </sql>

    <sql id="Query_Condition">
        <where>
            <if test="req.seqCode != null and req.seqCode != ''">
                AND seq_code LIKE CONCAT('%', #{req.seqCode}, '%')
            </if>
            <if test="req.seqName != null and req.seqName != ''">
                AND seq_name LIKE CONCAT('%', #{req.seqName}, '%')
            </if>
        </where>
    </sql>

    <select id="pageQuery" resultMap="BaseResultMap">
        SELECT
        <include refid="Base_Column_List"/>
        FROM ttd_sequence
        <include refid="Query_Condition"/>
        ORDER BY id DESC
    </select>




    <!-- 根据ID查询 -->
    <select id="selectById" resultMap="BaseResultMap">
        SELECT <include refid="Base_Column_List"/>
        FROM ttd_sequence
        WHERE id = #{id}
    </select>
</mapper>
